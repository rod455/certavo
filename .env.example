# Supabase — public client credentials (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — server only. NEVER commit. Used by scripts/seed.ts and Edge
# Functions (set as a Supabase Function secret, not in the client bundle).
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL (used for OG images, sitemap, canonical, share links)
NEXT_PUBLIC_SITE_URL=https://certavo.app

# Optional: absolute URL of the app logo for metadata (JSON-LD / OG).
# Defaults to the bundled /brand/logo-mark-1024.png. If you host it on Supabase
# Storage, prefer a PUBLIC bucket URL — signed URLs expire.
NEXT_PUBLIC_LOGO_URL=

# Future pack ingestion (n8n → ingest-pack Edge Function). Set as a Function
# secret in Supabase; the automation itself is not built yet.
INGEST_API_KEY=
